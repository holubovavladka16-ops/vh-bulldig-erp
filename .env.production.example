# Šablona pro produkční build (Vercel / npm run build)
# Zkopírujte jako .env.production nebo nastavte stejné proměnné ve Vercel → Settings → Environment Variables
# Používejte POUZE publishable/anon key – service role key do frontendu nepatří.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-anon-key

# Volitelné
VITE_INITIAL_ADMIN_EMAIL=admin@example.com
