# Lokální vývoj – zkopírujte do .env.local (soubor se necommituje)
# Lokální stack (npm run dev:local) přepíše hodnoty v .env.development.local automaticky.
# Lokální Supabase CLI (npx supabase start):
#   VITE_SUPABASE_URL=http://127.0.0.1:54321
#   VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
VITE_SUPABASE_URL=https://vas-projekt.supabase.co
VITE_SUPABASE_ANON_KEY=vase-anon-key

# Produkce (Vercel) – viz .env.production.example nebo proměnné ve Vercel dashboardu

# Volitelné – předvyplnění e-mailu při prvním nastavení administrátora
VITE_INITIAL_ADMIN_EMAIL=admin@vhbulldig.cz

# Pro skript npm run bootstrap-admin (soubor .env.local, necommitovat)
INITIAL_ADMIN_EMAIL=admin@vhbulldig.cz
INITIAL_ADMIN_PASSWORD=

# Pro npm run apply-migrations / npm run setup-complete
SUPABASE_DB_PASSWORD=
# Volitelně – celý connection string z Dashboard → Connect (má přednost před heslem výše)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Alternativa k DB heslu – spusťte npm run apply-migrations-dashboard
# Vytvořte na: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=